<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8F0"
    tools:context=".pizzaproject.PizzaDetailsActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:background="#C0392B"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <Button
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="→ חזרה"
                android:textColor="#FFFFFF"
                android:backgroundTint="#C0392B"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvPizzaTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="שם הפיצה"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:gravity="center" />

        </LinearLayout>

        <!-- תמונת הפיצה -->
        <ImageView
            android:id="@+id/ivPizzaImage"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:src="@drawable/classicPizza" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- שם ומחיר בסיס -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/tvPizzaName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="שם הפיצה"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A" />

                <TextView
                    android:id="@+id/tvPizzaPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₪0"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#C0392B" />

            </LinearLayout>

            <!-- ===== בחירת גודל ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="בחר גודל"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:layout_marginBottom="10dp" />

            <RadioGroup
                android:id="@+id/rgSize"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <RadioButton
                    android:id="@+id/rbSmall"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="S"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:buttonTint="#C0392B" />

                <RadioButton
                    android:id="@+id/rbMedium"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="M"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:checked="true"
                    android:buttonTint="#C0392B" />

                <RadioButton
                    android:id="@+id/rbLarge"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="L"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:buttonTint="#C0392B" />

                <RadioButton
                    android:id="@+id/rbXLarge"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="XL"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:buttonTint="#C0392B" />

            </RadioGroup>

            <!-- ===== תוספות ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="תוספות"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:layout_marginBottom="10dp" />

            <!-- שורה 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <CheckBox
                    android:id="@+id/cbTomato"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🍅 עגבניות +₪5"
                    android:textSize="13sp"
                    android:buttonTint="#C0392B" />

                <CheckBox
                    android:id="@+id/cbCorn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🌽 תירס +₪5"
                    android:textSize="13sp"
                    android:buttonTint="#C0392B" />

            </LinearLayout>

            <!-- שורה 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <CheckBox
                    android:id="@+id/cbOlives"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🫒 זיתים +₪5"
                    android:textSize="13sp"
                    android:buttonTint="#C0392B" />

                <CheckBox
                    android:id="@+id/cbMushrooms"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🍄 פטריות +₪5"
                    android:textSize="13sp"
                    android:buttonTint="#C0392B" />

            </LinearLayout>

            <!-- שורה 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <CheckBox
                    android:id="@+id/cbOnion"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🧅 בצל +₪5"
                    android:textSize="13sp"
                    android:buttonTint="#C0392B" />

                <CheckBox
                    android:id="@+id/cbPepper"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🫑 פלפל +₪5"
                    android:textSize="13sp"
                    android:buttonTint="#C0392B" />

            </LinearLayout>

            <!-- שורה 4 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <CheckBox
                    android:id="@+id/cbExtraCheese"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🧀 גבינה +₪8"
                    android:textSize="13sp"
                    android:buttonTint="#C0392B" />

                <CheckBox
                    android:id="@+id/cbPineapple"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🍍 אננס +₪6"
                    android:textSize="13sp"
                    android:buttonTint="#C0392B" />

            </LinearLayout>

            <!-- שורה 5 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <CheckBox
                    android:id="@+id/cbTuna"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🐟 טונה +₪8"
                    android:textSize="13sp"
                    android:buttonTint="#C0392B" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

            </LinearLayout>

            <!-- ===== סה"כ ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="סה״כ לתשלום:"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A" />

                <TextView
                    android:id="@+id/tvTotalPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₪0"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#C0392B" />

            </LinearLayout>

            <!-- כפתור הוספה לעגלה -->
            <Button
                android:id="@+id/btnAddToCart"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🛒 הוסף לעגלה"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#C0392B" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>