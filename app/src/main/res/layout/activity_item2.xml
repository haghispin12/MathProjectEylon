<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="14dp"
    android:layout_marginBottom="12dp"
    android:elevation="2dp">

    <!-- שורה עליונה — תמונה + פרטים -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <!-- תמונת הפיצה -->
        <ImageView
            android:id="@+id/ivPizzaImage"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:scaleType="centerCrop"
            android:src="@drawable/classicpizza"
            android:layout_marginEnd="12dp" />

        <!-- פרטים -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvPizzaName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="שם הפיצה"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A" />

                <TextView
                    android:id="@+id/tvPizzaPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₪0"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#C0392B" />

            </LinearLayout>

            <!-- גודל -->
            <TextView
                android:id="@+id/tvPizzaSize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="גודל: M"
                android:textSize="13sp"
                android:textColor="#999999"
                android:layout_marginTop="4dp" />

            <!-- תוספות -->
            <TextView
                android:id="@+id/tvPizzaExtras"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="תוספות: אין"
                android:textSize="13sp"
                android:textColor="#999999"
                android:layout_marginTop="4dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- כפתור מחיקה -->
    <Button
        android:id="@+id/btnDelete"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="🗑 הסר"
        android:textSize="12sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#E74C3C" />

</LinearLayout>