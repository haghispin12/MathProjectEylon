<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#FFF8F0"
    tools:context=".pizzaproject.launcher2">

    <!-- אמוג'י + כותרת -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🍕"
        android:textSize="70sp"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ברוכים הבאים!"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#C0392B"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pizza Project"
        android:textSize="16sp"
        android:textColor="#999999"
        android:layout_marginBottom="48dp" />

    <!-- כפתור כניסת מנהלים -->
    <Button
        android:id="@+id/btnAdmin"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="כניסת מנהלים"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#C0392B"
        android:layout_marginBottom="16dp" />

    <!-- כפתור כניסת לקוחות -->
    <Button
        android:id="@+id/btnCustomer"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="כניסת לקוחות"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#C0392B"
        android:layout_marginBottom="16dp" />

    <!-- כפתור הרשמה -->
    <Button
        android:id="@+id/btnRegister"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="אין לך חשבון? הירשם כאן"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#C0392B" />

</LinearLayout>